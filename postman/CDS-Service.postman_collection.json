{
  "info": {
    "name": "CDS Service",
    "description": "CDS Hooks：Discovery（GET /cds-services）與 Hook（POST egfr-check / ckd-risk）。\n變數 baseUrl 預設 http://127.0.0.1:3000；patientId 預設 patient-ckd-001。\n啟動服務：npm start；FHIR 需可連（FHIR_BASE_URL）。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3000"
    },
    {
      "key": "fhirBaseUrl",
      "value": "http://localhost:9090/fhir"
    },
    {
      "key": "patientId",
      "value": "patient-ckd-001"
    }
  ],
  "item": [
    {
      "name": "Discovery",
      "item": [
        {
          "name": "GET /cds-services",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/cds-services",
            "description": "回傳 services 清單（含 egfr-check、ckd-risk 與 prefetch 範本）。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Hooks",
      "item": [
        {
          "name": "POST /cds-services/egfr-check",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json; charset=utf-8"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hook\": \"patient-view\",\n  \"context\": {\n    \"patientId\": \"{{patientId}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/cds-services/egfr-check",
            "description": "步驟二主路徑；無 prefetch 時會以 fhirClient 向 FHIR 查詢。"
          },
          "response": []
        },
        {
          "name": "POST /cds-services/ckd-risk",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json; charset=utf-8"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hook\": \"patient-view\",\n  \"context\": {\n    \"patientId\": \"{{patientId}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/cds-services/ckd-risk",
            "description": "ckd-risk v1 為 prefetch-only（需要 patient/conditions/observations）。不帶 prefetch 會回 warning：prefetch required。"
          },
          "response": []
        },
        {
          "name": "POST /cds-services/egfr-check (with prefetch stub)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json; charset=utf-8"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hook\": \"patient-view\",\n  \"context\": {\n    \"patientId\": \"{{patientId}}\"\n  },\n  \"prefetch\": {\n    \"comment\": \"實際由 EHR 帶入 Bundle/Observation；此為結構範例，需替換為真實 FHIR JSON\"\n  }\n}"
            },
            "url": "{{baseUrl}}/cds-services/egfr-check",
            "description": "示範 prefetch 欄位位置；真測請用 EHR 回傳的 prefetch 或省略以走 FHIR fallback。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "FHIR TestData（5 samples）",
