{
  "info": {
    "name": "CDS Service — FHIR TestData（Import + Query）",
    "description": "匯入與查詢 input/tests/fhir/ 的 5 組測試資料（Patient + Observation）。\n\n**變數**\n- `fhirBaseUrl`：HAPI FHIR base（例：http://localhost:9090/fhir）\n\n**建議跑法**：先跑資料夾「01 Import（transaction）」→ 再跑「02 Query（GET/SEARCH）」驗證。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "fhirBaseUrl", "value": "http://localhost:9090/fhir" }
  ],
  "item": [
    {
      "name": "01 Import（transaction Bundles）",
      "item": [
        {
          "name": "Import case-01 (patient-ckd-101, eGFR 45, bad unit mL/min/1.73m2)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/fhir+json" },
              { "key": "Accept", "value": "application/fhir+json" }
            ],
            "url": "{{fhirBaseUrl}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"Bundle\",\n  \"type\": \"transaction\",\n  \"entry\": [\n    {\n      \"fullUrl\": \"urn:uuid:patient-ckd-101\",\n      \"resource\": {\n        \"resourceType\": \"Patient\",\n        \"id\": \"patient-ckd-101\",\n        \"active\": true,\n        \"name\": [\n          {\n            \"use\": \"official\",\n            \"family\": \"Wang\",\n            \"given\": [\"Case01\"]\n          }\n        ],\n        \"gender\": \"male\",\n        \"birthDate\": \"1970-01-01\"\n      },\n      \"request\": { \"method\": \"PUT\", \"url\": \"Patient/patient-ckd-101\" }\n    },\n    {\n      \"fullUrl\": \"urn:uuid:obs-egfr-101\",\n      \"resource\": {\n        \"resourceType\": \"Observation\",\n        \"id\": \"obs-egfr-101\",\n        \"status\": \"final\",\n        \"category\": [\n          {\n            \"coding\": [\n              {\n                \"system\": \"http://terminology.hl7.org/CodeSystem/observation-category\",\n                \"code\": \"laboratory\"\n              }\n            ]\n          }\n        ],\n        \"code\": {\n          \"coding\": [\n            {\n              \"system\": \"http://loinc.org\",\n              \"code\": \"62238-1\",\n              \"display\": \"Glomerular filtration rate/1.73 sq M.predicted [Volume Rate/Area] in Serum, Plasma or Blood by Creatinine-based formula (CKD-EPI)\"\n            }\n          ],\n          \"text\": \"eGFR\"\n        },\n        \"subject\": { \"reference\": \"Patient/patient-ckd-101\" },\n        \"effectiveDateTime\": \"2026-04-15T08:00:00+08:00\",\n        \"valueQuantity\": {\n          \"value\": 45,\n          \"unit\": \"mL/min/1.73m2\",\n          \"system\": \"http://unitsofmeasure.org\",\n          \"code\": \"mL/min/1.73m2\"\n        }\n      },\n      \"request\": { \"method\": \"PUT\", \"url\": \"Observation/obs-egfr-101\" }\n    },\n    {\n      \"fullUrl\": \"urn:uuid:obs-crea-101\",\n      \"resource\": {\n        \"resourceType\": \"Observation\",\n        \"id\": \"obs-crea-101\",\n        \"status\": \"final\",\n        \"category\": [\n          {\n            \"coding\": [\n              {\n                \"system\": \"http://terminology.hl7.org/CodeSystem/observation-category\",\n                \"code\": \"laboratory\"\n              }\n            ]\n          }\n        ],\n        \"code\": {\n          \"coding\": [\n            {\n              \"system\": \"http://loinc.org\",\n              \"code\": \"2160-0\",\n              \"display\": \"Creatinine [Mass/volume] in Serum or Plasma\"\n            }\n          ],\n          \"text\": \"Creatinine\"\n        },\n        \"subject\": { \"reference\": \"Patient/patient-ckd-101\" },\n        \"effectiveDateTime\": \"2026-04-15T08:00:00+08:00\",\n        \"valueQuantity\": {\n          \"value\": 1.5,\n          \"unit\": \"mg/dL\",\n          \"system\": \"http://unitsofmeasure.org\",\n          \"code\": \"mg/dL\"\n        }\n      },\n      \"request\": { \"method\": \"PUT\", \"url\": \"Observation/obs-crea-101\" }\n    }\n  ]\n}\n"
            },
            "description": "POST 到 FHIR base，transaction Bundle 會用 PUT 建立/覆蓋固定 id。"
          },
          "response": []
        },
