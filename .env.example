<!--
更新時間：2026-04-22 14:00
作者：CDS Service
摘要：PR #3 Copilot review：新增 TB_VALUESET_BASE_URL，供 tbValueSetLoader.ts 組裝 ValueSet canonical URL 使用。

更新時間：2026-04-20 14:48
作者：CDS Service
摘要：補齊 .env.example 註解：急診 72hr-revisit 與 infection-control 參數影響範圍、USE_ELM 行為與 TS_FALLBACK／rule-engine 說明
-->

FHIR_BASE_URL=http://localhost:9090/fhir
# Discovery `href` 的公開基底（勿尾隨 `/`）；主 CDS（port 3000）對外入口
CDS_PUBLIC_BASE_URL=http://localhost:3000
# 複查/指引連結（cards 的 source.url）；可替換為院內指引網址
CDS_GUIDELINE_URL=https://example.org/guidelines
# 與主 CDS、急診獨立 CDS **共用**：
# - `true`：兩程序皆會嘗試以 ELM（cql-execution）執行「已支援之規則」
# - 任何 ELM 執行失敗：會自動走既有 TypeScript 路徑，並將 cards extension `urn:cds-service:rule-engine` 設為 `TS_FALLBACK`
# - 成功走 ELM：`urn:cds-service:rule-engine` 會是 `ELM`
USE_ELM=false
PORT=3000
HOST=0.0.0.0

# 急診獨立 CDS（第二程序；npm run dev:emergency）
# 注意：這些設定只影響急診程序（預設 port 3001），不影響主 CDS（port 3000）
EMERGENCY_CDS_PORT=3001
EMERGENCY_CDS_HOST=0.0.0.0
# 急診 Discovery 中 `href` 的公開基底（勿尾隨 `/`）
EMERGENCY_CDS_PUBLIC_BASE_URL=http://localhost:3001

# 72hr-revisit：返診偵測的計數規則
# - 只統計「時間窗內（WindowHours）開始」的 Encounter
# - CountInWindow >= MinEncounters 時才會出警示卡
EMERGENCY_REVISIT_WINDOW_HOURS=72
EMERGENCY_REVISIT_MIN_ENCOUNTERS=2

# 72hr-revisit：可選的 Encounter.class 過濾（逗號分隔）
# - 未設定/空值：不過濾，時間窗內所有 Encounter 都納入計數
# - 有設定：僅 Encounter.class.code 命中清單者才納入計數（可能使 CountInWindow 變小，進而不觸發警示）
# 例：EMERGENCY_ENCOUNTER_CLASS_CODES=EMER,AMB
EMERGENCY_ENCOUNTER_CLASS_CODES=EMER

# infection-control-warning：感控預警線索來源控制
# - `false`：使用 Flag + 用藥 + 診斷 的線索（通常較敏感）
# - `true`：完全忽略 Flag，只用「用藥＋診斷」判斷（通常較不敏感、可降低過度警示）
EMERGENCY_INFECT_CTRL_SKIP_FLAGS=false

# TB Detection：ValueSet canonical URL 前綴（勿尾隨 `/`）
# 預設值：https://fhir.your-hosp.org.tw
# 替換為院內 FHIR server 的實際 canonical base URL
TB_VALUESET_BASE_URL=https://fhir.your-hosp.org.tw
