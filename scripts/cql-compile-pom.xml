<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>local.cds-service</groupId>
  <artifactId>cql-to-elm-helper</artifactId>
  <version>1.0.0</version>
  <packaging>pom</packaging>
  <description>Pull CQFramework cql-to-elm-cli + deps for one-off ELM generation (see docs/cql_elm.md)</description>
  <dependencies>
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>cql-to-elm-cli</artifactId>
      <version>3.26.0</version>
    </dependency>
    <!-- Explicit runtime deps: upstream cql-to-elm-cli POM is invalid for Maven (missing hapi version), so transitive graph is not applied -->
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>cql-to-elm</artifactId>
      <version>3.26.0</version>
    </dependency>
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>cqf-fhir</artifactId>
      <version>3.26.0</version>
    </dependency>
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>cqf-fhir-npm</artifactId>
      <version>3.26.0</version>
    </dependency>
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>quick</artifactId>
      <version>3.26.0</version>
    </dependency>
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>qdm</artifactId>
      <version>3.26.0</version>
    </dependency>
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>model-jaxb</artifactId>
      <version>3.26.0</version>
    </dependency>
    <dependency>
      <groupId>info.cqframework</groupId>
      <artifactId>elm-jaxb</artifactId>
      <version>3.26.0</version>
    </dependency>
    <dependency>
      <groupId>net.sf.jopt-simple</groupId>
      <artifactId>jopt-simple</artifactId>
      <version>4.7</version>
    </dependency>
    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-simple</artifactId>
      <version>2.0.13</version>
    </dependency>
    <dependency>
      <groupId>org.glassfish.jaxb</groupId>
      <artifactId>jaxb-runtime</artifactId>
      <version>4.0.5</version>
    </dependency>
    <dependency>
      <groupId>org.eclipse.persistence</groupId>
      <artifactId>org.eclipse.persistence.moxy</artifactId>
      <version>4.0.2</version>
    </dependency>
    <dependency>
      <groupId>ca.uhn.hapi.fhir</groupId>
      <artifactId>hapi-fhir-structures-r5</artifactId>
      <version>7.6.1</version>
    </dependency>
  </dependencies>
  <build>
    <plugins>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.1.0</version>
        <configuration>
          <mainClass>org.cqframework.cql.cql2elm.cli.Main</mainClass>
          <classpathScope>runtime</classpathScope>
          <!-- POM lives in scripts/; translator resolves model paths from cwd -->
          <workingDirectory>${project.basedir}/..</workingDirectory>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
